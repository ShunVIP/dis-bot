# ViPik / dis-bot environment template.
# Copy to KGTD.env and fill only on the machine/server that runs the bot.
# Never commit real tokens, VPS passwords, databases or SSH keys.

# --- Discord bot ---
tok=YOUR_DISCORD_BOT_TOKEN
DISCORD_BOT_TOKEN=YOUR_DISCORD_BOT_TOKEN

# --- Discord OAuth for future site/app ---
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=http://127.0.0.1:3000/auth/discord/callback
DISCORD_OAUTH_SCOPES=identify email guilds guilds.members.read connections
# Required for Discord OAuth: comma-separated guild ids whose members may enter.
APP_ALLOWED_GUILD_IDS=
# Optional recovery/bootstrap owners. Never grant owner to an arbitrary first login.
APP_OWNER_USER_IDS=

# --- Web/app session and bot API bridge ---
APP_BASE_URL=http://127.0.0.1:3000
APP_API_HOST=127.0.0.1
APP_API_PORT=3000
SESSION_SECRET=
JWT_SECRET=
BOT_API_TOKEN=

# --- Private voice / LiveKit ---
# Production uses trusted Tailscale HTTPS/WSS; scripts/install_private_livekit.sh fills these values.
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# --- SQLite/runtime paths ---
DATABASE_DIR=./datebase
MODELS_DIR=./models
UPLOADS_DIR=./datebase/uploads
UPLOAD_MAX_MB=25

# --- Steam ---
STEAM_API_KEY=YOUR_STEAM_API_KEY

# --- Riot / League of Legends ---
RIOT_API_KEY=YOUR_RIOT_API_KEY
RIOT_PLATFORM_REGION=ru
RIOT_REGIONAL_ROUTING=europe

# --- Server safety toggles ---
BOT_SERVER_MODE=true
ALLOW_FULL_MAINTENANCE_ON_SERVER=false
ENABLE_DAILY_MARKOV_RETRAIN_ON_SERVER=false
ENABLE_DAILY_MARKOV_COLLECTION_ON_SERVER=true
ENABLE_WWM_KB_REFRESH_ON_SERVER=false
DAILY_MARKOV_RETRAIN_HOUR=3
DAILY_MARKOV_RETRAIN_MINUTE=15

# --- Free local conversational model (run Ollama on the private PC/Tailscale) ---
# Leave URL empty to use built-in templates and Markov parody fallback only.
LOCAL_CHAT_API_URL=
LOCAL_CHAT_MODEL=qwen3:8b
LOCAL_CHAT_API_TOKEN=
LOCAL_CHAT_TIMEOUT_SECONDS=45

# --- Built-in admin panel ---
WEB_ADMIN_ENABLED=false
WEB_ADMIN_HOST=127.0.0.1
WEB_ADMIN_PORT=8080
WEB_ADMIN_PUBLIC_URL=
WEB_ADMIN_DISCORD_REDIRECT_URI=http://127.0.0.1:8080/auth/discord/callback
WEB_ADMIN_CHANNEL_NAME=whitehouse
WEB_ADMIN_CHANNEL_ID=0
WEB_ADMIN_TOKEN=
WEB_ADMIN_ALLOWED_IPS=
WEB_ADMIN_TITLE=ViPik Bot Control

# --- Deployment notes, not consumed directly by the bot ---
VPS_HOST=
VPS_USER=
VPS_APP_DIR=/opt/dis-bot
TAILSCALE_HOSTNAME=
